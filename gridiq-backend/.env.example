ENV=dev

# Default: SQLite file next to the backend (no Postgres/Docker required).
# Relative sqlite URLs are rewritten to gridiq-backend/ so cwd does not create duplicate .db files.
DATABASE_URL=sqlite:///./gridiq.db

# Optional: PostgreSQL (Docker: `docker compose up -d db`). Use `localhost` when running
# uvicorn on your machine; use `db` only when the API runs inside Docker Compose.
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/gridiq

JWT_SECRET=change-me
JWT_ALG=HS256
ACCESS_TOKEN_MINUTES=30

# Chat: set GEMINI_API_KEY for live AI (Google Gemini only).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional CSV for non-localhost frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
